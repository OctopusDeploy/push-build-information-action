{
  "author": "Octopus Deploy",
  "bugs": {
    "url": "https://github.com/OctopusDeploy/push-build-information-action/issues"
  },
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/github": "5.1.1",
    "@octokit/webhooks-types": "6.11.0",
    "@octopusdeploy/api-client": "3.11.0"
  },
  "overrides": {
    "form-data": "4.0.5"
  },
  "description": "GitHub Action to Push Build Information to Octopus Deploy",
  "devDependencies": {
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "9.39.4",
    "@stylistic/eslint-plugin": "5.10.0",
    "@types/jest": "29.5.14",
    "@types/node": "24.7.2",
    "@types/tmp": "0.2.6",
    "@typescript-eslint/eslint-plugin": "8.57.1",
    "@typescript-eslint/parser": "8.57.1",
    "esbuild": "^0.27.4",
    "eslint": "9.39.4",
    "eslint-plugin-github": "6.0.0",
    "eslint-plugin-jest": "29.15.0",
    "globals": "16.5.0",
    "jest": "29.7.0",
    "jest-circus": "29.7.0",
    "jest-junit": "15.0.0",
    "js-yaml": "4.1.1",
    "prettier": "2.8.8",
    "tmp": "0.2.5",
    "ts-jest": "29.4.6",
    "typescript": "5.9.3"
  },
  "homepage": "https://github.com/OctopusDeploy/push-build-information-action#readme",
  "jest": {
    "clearMocks": true,
    "collectCoverage": true,
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "moduleFileExtensions": [
      "js",
      "ts"
    ],
    "setupFiles": [
      "<rootDir>/src/test-setup.ts"
    ],
    "testEnvironment": "node",
    "testMatch": [
      "**/*.test.ts"
    ],
    "testRunner": "jest-circus/runner",
    "testTimeout": 10000,
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "useESM": true,
          "tsconfig": {
            "module": "ESNext",
            "moduleResolution": "bundler"
          }
        }
      ]
    },
    "verbose": true
  },
  "jest-junit": {
    "outputDirectory": "reports",
    "outputName": "jest-junit.xml",
    "ancestorSeperator": " > ",
    "uniqueOutputName": "false",
    "suiteNameTemplate": "{filepath}",
    "classNameTemplate": "{classname}",
    "titleTemplate": "{title}"
  },
  "keywords": [
    "cli",
    "deployment",
    "octopus-deploy",
    "github-actions"
  ],
  "license": "Apache-2.0",
  "main": "src/index.ts",
  "name": "push-build-information-action",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OctopusDeploy/push-build-information-action.git"
  },
  "scripts": {
    "all": "npm run format && npm run build && npm test",
    "build": "tsc --noEmit --newLine lf",
    "format": "prettier --write **/*.ts",
    "format-check": "prettier --check **/*.ts",
    "prebuild": "eslint src/**/*.ts",
    "postbuild": "esbuild src/index.ts --bundle --platform=node --outfile=dist/index.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --ci --reporters=default --reporters=jest-junit"
  },
  "version": "4.1.0"
}
